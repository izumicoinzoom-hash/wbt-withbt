# 省略（既存の https 強制など）

# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# NFCタグ用: トップ(/)で nfcStandalone と nfcTaskId が付いていたら工程管理アプリ(/kiyota/)へリダイレクト
RewriteCond %{QUERY_STRING} nfcStandalone=1 [NC]
RewriteCond %{QUERY_STRING} nfcTaskId= [NC]
RewriteRule ^$ /kiyota/ [R=302,L,QSA]

RewriteRule ^index\.php$ - [L]

# /kiyota と /demo は WordPress に渡さず、実ファイルを表示する
RewriteCond %{REQUEST_URI} ^/kiyota [OR]
RewriteCond %{REQUEST_URI} ^/demo
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress